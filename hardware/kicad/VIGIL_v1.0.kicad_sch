  (text "SIGNAL FLOW:\n\nPVDF Sensors (temples) -> AD8606 (U5) -> nRF52840 ADC\nLIS3DH (U2) -> I2C -> nRF52840\nTMP117 (U3) -> I2C -> nRF52840\nICS-43434 (U4) -> I2S -> nRF52840\nnRF52840 -> BLE 5.0 -> Phone/Tablet\n\nPOWER:\nUSB-C (J1) -> BQ24072 (U7) -> LiPo Battery\nBattery -> TPS62840 (U6) + L1 -> 3.3V Rail\n\nI2C BUS: SDA + SCL with 4.7k pull-ups (R1, R2)"
